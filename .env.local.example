# AEM GraphQL Endpoint Configuration
# Copy this file to .env.local and fill in the values for your AEM instance.

# AEM Publish Host (required)
# For AEM Cloud Service, use the publish instance URL pattern:
# https://publish-p<program>-e<env>.adobeaemcloud.com
NEXT_PUBLIC_AEM_HOST=https://publish-p178261-e1872848.adobeaemcloud.com

# AEM GraphQL Endpoint path (optional)
# Leave unset to let the app auto-discover the endpoint. Candidates tried:
#   /content/_cq_graphql/acssandboxemea02jcadev/endpoint.json
#   /content/_cq_graphql/global/endpoint.json
#   /content/cq:graphql/acssandboxemea02jcadev/endpoint.json
#   /content/cq:graphql/global/endpoint.json
#   /content/graphql/global/endpoint.json
# Set this explicitly once you know the correct path for your tenant, e.g.:
# NEXT_PUBLIC_AEM_GRAPHQL_ENDPOINT=/content/_cq_graphql/global/endpoint.json

# Optional: AEM Bearer token for authenticated requests
# Use this if your publish instance requires authentication
# NEXT_PUBLIC_AEM_AUTH=your-bearer-token-here
