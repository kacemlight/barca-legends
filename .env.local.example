# AEM GraphQL Endpoint Configuration
# Replace with your actual AEM publish instance details

# AEM Publish Host (e.g., https://publish-p<program>-e<env>.adobeaemcloud.com)
NEXT_PUBLIC_AEM_HOST=https://publish-XXXXX.adobeaemcloud.com

# AEM GraphQL Endpoint path
NEXT_PUBLIC_AEM_GRAPHQL_ENDPOINT=/content/graphql/global/endpoint.json

# Optional: AEM Bearer token for authenticated requests
# NEXT_PUBLIC_AEM_AUTH=your-bearer-token-here
